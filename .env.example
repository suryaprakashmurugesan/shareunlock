# Secure File Vault Configuration

# Server Configuration
# For local development:
# BASE_URL=http://localhost:50000
# SERVER_HOST=localhost
# SERVER_PORT=50000

# For network sharing (use your machine IP):
# BASE_URL=http://192.168.x.x:50000
# SERVER_HOST=0.0.0.0
# SERVER_PORT=50000

# For public deployment (use your domain):
# BASE_URL=https://yourdomain.com
# SERVER_HOST=0.0.0.0
# SERVER_PORT=50000

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@secure-file-vault.com

# Database (optional, defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost/secure_file_vault

# Security
SECRET_KEY=change-this-to-a-random-secret-key
